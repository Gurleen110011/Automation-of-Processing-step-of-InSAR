# Single-runner PyGMTSAR workflow configuration.
# Edit EO_IITD_ROOT first, then run: ./run_all.sh all

EO_IITD_ROOT="${EO_IITD_ROOT:-$HOME/Projects/EO_IITD}"
MASTER_NAME="${MASTER_NAME:-LocalProcessing}"

# AOI selection method 1: all combinations of groups and indices.
# This selects A1-A10, B1-B10, and C1-C10.
AOI_GROUPS="ABC"
AOI_INDICES="1-9"

# AOI selection method 2: explicit AOIs. Leave empty to use the values above.
# Example: AOI_LIST="A1,A2,A3,B1,C10"
AOI_LIST=""

SLC_SOURCE="$EO_IITD_ROOT/AutoPreprocessing/SLC_unzipped"
DEM_ROOT="$EO_IITD_ROOT/AutoPreprocessing/Outputs/07_dem_outputs/clipped_dem_netcdfs"
AOI_ROOT="$EO_IITD_ROOT/AutoPreprocessing/Outputs/06_buffered_processing_aois/single_files/geojson"
AOI_INLINE_FILE=""
ORBIT_DIR="$SLC_SOURCE"
SCRATCH_ROOT="$EO_IITD_ROOT/AutoProcessing/ProcessingRuns"
HOME_RESULTS="$EO_IITD_ROOT/AutoProcessing/CollectedResults"

# Input staging. Hardlinks are fastest when source and destination are on the
# same native Linux filesystem.
LINK_MODE="hardlink"
ORBIT_LINK_MODE="hardlink"
COPY_DEM=0

# Processing configuration for each AOI.
REFERENCE_DATE="2025-01-11"
PAIR_LIMIT=2
CORR_LIMIT=0.2
BASELINE_DAYS=60
BASELINE_METERS=250
NCPUS_PER_AOI=4
MEMORY_GB_PER_AOI=12
DASK_WORKERS_PER_AOI=2

# Number of AOIs processed simultaneously within each scientific step.
# Keep this at 1 unless the machine/HPC allocation has enough total resources.
MAX_PARALLEL_AOIS="${MAX_PARALLEL_AOIS:-1}"

# Set to 1 to rerun scientific steps even when their success markers exist.
FORCE_STEPS="${FORCE_STEPS:-0}"

UNZIP_WORKERS=4
CHECK_RUNTIME_DEPS=0
INCLUDE_HEAVY_RESULTS=0
RESUME_EXISTING_OUTPUTS=0
NO_DOWNLOAD_ORBITS=0
ALLOW_PARALLEL_HDF5=0
